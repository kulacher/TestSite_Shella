{% assign short_id = section.id | slice: -10, 10 %}

<div id="spro-{{ section.id }}" class="spro-section" spro-section>

  <div class="spro-container" spro-container>

    {% if section.settings.headline != '' or section.settings.text != '' %}
      <div class="spro-headline" spro-column>
        {% if section.settings.headline != '' %}<h2>{{ section.settings.headline }}</h2>{% endif %}
        {% if section.settings.text != '' %}<p>{{ section.settings.text }}</p>{% endif %}
      </div>
    {% endif %}

    {% if request.design_mode %}
    <div style="display:none;">
    {% assign tab_index = 1 %}
    {% for block in section.blocks %}

      
      {% if block.type == "tab" %}
        {% assign tab_index = forloop.index %}
        <span data-index="{{ tab_index }}" {{ block.shopify_attributes }}></span>
      {% else %}
        <span data-index="{{ tab_index }}" {{ block.shopify_attributes }}></span>
      {% endif %}

    {% endfor %}
    </div>
    {% endif %}

    <div class="spro-links-wrapper">
    <div class="spro-links"><ul style="text-align: {{ section.settings.tab_alignment }};">
    {% for block in section.blocks %}
        {% if block.type != "tab" and forloop.index == 1 %}
          <li><a class="spro-link" href="#spro-tab_{{ short_id }}_{{ forloop.index }}" data-index="{{ forloop.index }}" active>
            <span class="spro-icon"><svg xmlns="http://www.w3.org/2000/svg" class="spro-icon-svg" viewBox="0 -960 960 960"><path d="M570-104q-23 23-57 23t-57-23L104-456q-11-11-17.5-26T80-514v-286q0-33 23.5-56.5T160-880h286q17 0 32 6.5t26 17.5l352 353q23 23 23 56.5T856-390L570-104Zm-57-56 286-286-353-354H160v286l353 354ZM260-640q25 0 42.5-17.5T320-700q0-25-17.5-42.5T260-760q-25 0-42.5 17.5T200-700q0 25 17.5 42.5T260-640ZM160-800Z"/></svg></span><span>Default Tab</span></a>
         </li>
