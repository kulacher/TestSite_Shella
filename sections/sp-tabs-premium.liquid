    function gotoTab_{{ short_id }}(index) {
      var links = document.querySelectorAll('#spro-{{ section.id }} .spro-link, #spro-{{ section.id }} .spro-link-mobile');
      var tabs = document.querySelectorAll('#spro-{{ section.id }} .spro-tab');
  
      // remove active
      for(x=0; x<links.length; x++) {
        links[x].removeAttribute('active');
      }

      var link = document.querySelector('#spro-{{ section.id }} .spro-link[data-index="' + index + '"]');
      link.setAttribute('active', '');

      var mobileLink = document.querySelector('#spro-{{ section.id }} .spro-link-mobile[data-index="' + index + '"]');
      mobileLink.setAttribute('active', '');
      
      // set active tab
      for(x=0; x<tabs.length; x++) {
        tabs[x].removeAttribute('active');
      }
      
      var tab = document.querySelector('#spro-{{ section.id }} .spro-tab[data-index="' + index + '"]');
      
      if(tab)tab.setAttribute('active', '');
    }

    var links = document.querySelectorAll('#spro-{{ section.id }} .spro-link, #spro-{{ section.id }} .spro-link-mobile');
    
    for(var x=0; x<links.length; x++) {

        links[x].addEventListener('click', function(e) {
          var index = e.target.getAttribute('data-index');
          var el = e.target;
          gotoTab_{{ short_id }}(index);

          // scroll into view for mobile
          if(el.classList.contains('spro-link-mobile')) {

            // offset
            var yOffset = -(el.offsetHeight); 
            var y = el.getBoundingClientRect().top + window.scrollY + yOffset;
            window.scrollTo({top: y, behavior: 'smooth'});
            // console.log(`scroll to ${y}`);
          }

          e.preventDefault();
        });
        
    }
</script>

<script>
  if (Shopify.designMode) {
    console.log('[spro-premium] designMode');
    document.addEventListener('shopify:block:select', function(e) {
      console.log('[spro-premium] shopify:block:select');

      // goto index
      var index = e.target.getAttribute('data-index');

      gotoTab_{{ short_id }}(index);

      // reset JS
      var links = document.querySelectorAll('#spro-{{ section.id }} .spro-link, #spro-{{ section.id }} .spro-link-mobile');
    
      for(var x=0; x<links.length; x++) {
  
          links[x].addEventListener('click', function(e) {
            var index = e.target.getAttribute('data-index');
            gotoTab_{{ short_id }}(index);
          });
          
      }
    });
} 
</script>

